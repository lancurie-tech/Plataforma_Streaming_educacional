# Copiar para `.env.development` (não commitar — está no .gitignore).
#
# `npm run dev` usa `--mode production` e carrega `.env.production` (Firebase prod streaming-educacional).
# Este ficheiro só é lido em `npm run dev:development-env` ou `npm run build:dev`.
# Valores típicos: App Web de um projeto Firebase só de desenvolvimento (ex.: streaming-educacional-dev).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=

VITE_FIREBASE_FUNCTIONS_REGION=southamerica-east1

# Multi-tenant por subdomínio (ex.: acme.seudominio.com)
# VITE_PUBLIC_APP_APEX_DOMAIN=seudominio.com
# VITE_PUBLIC_APP_ORIGIN=https://seudominio.com
# Em localhost, simula um tenant: VITE_PUBLIC_TENANT_SLUG_DEV=acme

# Opcional — App Check (reCAPTCHA v3)
# VITE_FIREBASE_APPCHECK_SITE_KEY=
# VITE_FIREBASE_APPCHECK_DEBUG=true

# Opcional — curso Saúde Mental (admin / vendedor)
# VITE_SAUDE_MENTAL_COURSE_ID=
# VITE_SAUDE_MENTAL_INSTRUMENT_MODULE_IDS=id1,id2,id3
