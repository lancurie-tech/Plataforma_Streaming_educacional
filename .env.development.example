# Copiar para `.env.development` (não commitar — está no .gitignore).
# Usado em `npm run dev` e em `npm run build:dev`.
# Valores: Firebase Console → Definições do projeto → App Web do projeto **DEV** (ex.: medivox-sp-dev).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=

VITE_FIREBASE_FUNCTIONS_REGION=southamerica-east1

# Opcional — App Check (reCAPTCHA v3)
# VITE_FIREBASE_APPCHECK_SITE_KEY=
# VITE_FIREBASE_APPCHECK_DEBUG=true

# Opcional — curso Saúde Mental (admin / vendedor)
# VITE_SAUDE_MENTAL_COURSE_ID=
# VITE_SAUDE_MENTAL_INSTRUMENT_MODULE_IDS=id1,id2,id3
