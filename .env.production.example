# Copiar para `.env.production` ou `.env.production.local` (não commitar).
# Usado em `npm run build`, `npm run preview` e `npm run prod`.
#
# Em equipas, costuma não haver chaves de prod na máquina: produção vem só da CI (GitHub Secrets).
# Usa este ficheiro só se precisares de um build local idêntico ao de produção.
# Valores: app Web do Firebase **PROD** (ex.: streaming-educacional).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_FIREBASE_FUNCTIONS_REGION=southamerica-east1

# Multi-tenant por subdomínio (obrigatório em produção se usar slug.cliente.com)
# VITE_PUBLIC_APP_APEX_DOMAIN=seudominio.com
# VITE_PUBLIC_APP_ORIGIN=https://seudominio.com

# Opcional — App Check
# VITE_FIREBASE_APPCHECK_SITE_KEY=
# Em localhost com site key preenchida: sem debug o App Check não inicia (evita 403 do reCAPTCHA).
# Com enforcement no Firebase e testes locais: VITE_FIREBASE_APPCHECK_DEBUG=true + token no Console.
# VITE_FIREBASE_APPCHECK_DEBUG=true

# Opcional — Saúde Mental
# VITE_SAUDE_MENTAL_COURSE_ID=
# VITE_SAUDE_MENTAL_INSTRUMENT_MODULE_IDS=
