rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    /** Operador da plataforma (custom claim no token). Não confundir com `admin` no documento `users`. */
    function isMasterAdmin() {
      return signedIn() && request.auth.token.master_admin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userData().role == 'admin';
    }

    function isVendedor() {
      return signedIn() && userData().role == 'vendedor';
    }

    /**
     * Tenant lógico do usuário autenticado.
     * Transição Fase 1: prioriza `tenantId`; fallback para `companyId`.
     */
    function actorTenantId() {
      let d = userData();
      return d.tenantId != null ? d.tenantId : d.companyId;
    }

    function belongsToActorTenant(tenantId) {
      return signedIn() && actorTenantId() != null && actorTenantId() == tenantId;
    }

    /**
     * Catálogo marketplace: subcoleção `modules` sob o doc fixo `catalog/platform`.
     * Path: `catalog/platform/modules/{moduleId}`.
     */
    function marketplaceCatalogPath(moduleId) {
      return /databases/$(database)/documents/catalog/platform/modules/$(moduleId);
    }

    function marketplaceCatalogRequestable(moduleId) {
      return exists(marketplaceCatalogPath(moduleId))
        && (get(marketplaceCatalogPath(moduleId)).data.status == 'active'
          || get(marketplaceCatalogPath(moduleId)).data.status == 'beta');
    }

    /** Empresa está na lista do vendedor (`managedCompanyIds` deve ser um array no Firestore). */
    function sellerManagesCompany(companyId) {
      return isVendedor()
        && userData().managedCompanyIds is list
        && (companyId in userData().managedCompanyIds);
    }

    function vendedorCanReadStudentUserDoc() {
      return isVendedor()
        && resource.data.role == 'student'
        && resource.data.keys().hasAll(['companyId'])
        && resource.data.companyId != null
        && sellerManagesCompany(resource.data.companyId);
    }

    /** Progresso e certificados de alunos das empresas da carteira (subcoleções de `users`). */
    function vendedorCanReadStudentUserSubpaths(studentUid) {
      let ref = /databases/$(database)/documents/users/$(studentUid);
      return isVendedor()
        && exists(ref)
        && get(ref).data.role == 'student'
        && get(ref).data.keys().hasAll(['companyId'])
        && get(ref).data.companyId != null
        && sellerManagesCompany(get(ref).data.companyId);
    }

    function enrolledIn(courseId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/courses/$(courseId));
    }

    function studentMustHaveActiveCompany() {
      let d = userData();
      return d.role == 'student' && d.keys().hasAll(['companyId']) && d.companyId != null;
    }

    function companyIsActive(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data.active == true;
    }

    function courseAllowedForUserCompany(courseId) {
      let companyId = userData().companyId;
      let p = /databases/$(database)/documents/companies/$(companyId)/allowedCourses/$(courseId);
      return exists(p)
        && (!get(p).data.keys().hasAll(['expiresAt']) || get(p).data.expiresAt > request.time);
    }

    function canReadCourseContent(courseId) {
      return isAdmin()
        || isVendedor()
        || (enrolledIn(courseId)
            && (!studentMustHaveActiveCompany()
                || (companyIsActive(userData().companyId)
                    && courseAllowedForUserCompany(courseId))));
    }

    /**
     * Módulos: checa o documento pai `courses/{courseId}` (no filho `resource` é o módulo).
     * No documento do curso use `allow read` com `resource.data` — combina melhor com queries `list`.
     */
    function parentCourseCatalogPublic(courseId) {
      let p = /databases/$(database)/documents/courses/$(courseId);
      return exists(p) && get(p).data.catalogPublished == true;
    }

    match /companies/{companyId} {
      allow read: if isAdmin()
        || (signedIn() && userData().companyId == companyId)
        || sellerManagesCompany(companyId);
      allow create, update, delete: if isAdmin();

      match /allowedCourses/{courseId} {
        allow read: if isAdmin()
          || (signedIn() && userData().companyId == companyId)
          || sellerManagesCompany(companyId);
        allow create, update, delete: if isAdmin();
      }

      /**
       * Chaves de cadastro em texto (doc `archive`).
       * Leitura: admin ou vendedor da empresa. Escrita: admin no cliente (após callable) ou Admin SDK;
       * exclusão só via Admin SDK ao apagar a empresa.
       */
      match /adminRegistrationKeys/{docId} {
        allow read: if isAdmin() || sellerManagesCompany(companyId);
        allow create, update: if isAdmin() && docId == 'archive';
        allow delete: if false;
      }
    }

    /**
     * Índice público por subdomínio: lê anónimo; escreve só master.
     * `enabledModuleIds` espelha o contrato para a UI pública (navegação / módulos).
     */
    match /tenantPublicSlugs/{slug} {
      allow read: if true;
      allow create, update, delete: if isMasterAdmin();
    }

    /**
     * Base multi-tenant (Fase 1):
     * - `tenants/{tenantId}`: metadados do cliente.
     * - `tenants/{tenantId}/entitlements/current`: módulos e limites efetivos.
     * - `plans/{planId}`: catálogo de planos.
     */
    match /tenants/{tenantId} {
      allow read: if isMasterAdmin() || belongsToActorTenant(tenantId);
      allow create, update, delete: if isMasterAdmin();

      match /entitlements/{docId} {
        allow read: if isMasterAdmin() || belongsToActorTenant(tenantId);
        allow create, update, delete: if isMasterAdmin();
      }

      /** Identidade visual pública (merge sobre `siteContent/branding` no cliente). */
      match /public/{docId} {
        allow read: if true;
        allow create, update, delete: if isMasterAdmin()
          || (isAdmin() && belongsToActorTenant(tenantId));
      }
    }

    match /plans/{planId} {
      allow read: if signedIn();
      allow create, update, delete: if isMasterAdmin();
    }

    match /catalog/{catalogDoc}/modules/{moduleId} {
      allow read: if isMasterAdmin()
        || (isAdmin() && catalogDoc == 'platform');
      allow create, update, delete: if isMasterAdmin() && catalogDoc == 'platform';
    }

    /**
     * Pedidos de ativação de módulo (Fase 4): admin do tenant abre ticket; master aprova.
     */
    match /marketplaceRequests/{requestId} {
      allow read: if isMasterAdmin()
        || (isAdmin()
          && resource.data.keys().hasAll(['tenantId'])
          && belongsToActorTenant(resource.data.tenantId));
      allow create: if isAdmin()
        && belongsToActorTenant(request.resource.data.tenantId)
        && request.resource.data.keys().hasAll(['tenantId', 'moduleId', 'commercialModuleId', 'status'])
        && request.resource.data.status == 'pending'
        && request.resource.data.tenantId == actorTenantId()
        && request.resource.data.moduleId == request.resource.data.commercialModuleId
        && marketplaceCatalogRequestable(request.resource.data.moduleId)
        && get(marketplaceCatalogPath(request.resource.data.moduleId)).data.commercialModuleId
          == request.resource.data.commercialModuleId;
      allow update: if isMasterAdmin();
      allow delete: if false;
    }

    /**
     * Coleção piloto para validar isolamento lógico por `tenantId`.
     * Requer campo `tenantId` no documento.
     */
    match /tenantPilotData/{docId} {
      allow read: if isMasterAdmin()
        || isAdmin()
        || (resource.data.keys().hasAll(['tenantId'])
            && belongsToActorTenant(resource.data.tenantId));
      allow create, update: if isMasterAdmin()
        || isAdmin()
        || (request.resource.data.keys().hasAll(['tenantId'])
            && belongsToActorTenant(request.resource.data.tenantId));
      allow delete: if isMasterAdmin()
        || isAdmin()
        || (resource.data.keys().hasAll(['tenantId'])
            && belongsToActorTenant(resource.data.tenantId));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || vendedorCanReadStudentUserDoc();
      allow create: if false;
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.cpf == resource.data.cpf
        && request.resource.data.companyRoleId == resource.data.companyRoleId
        && request.resource.data.companyDepartmentId == resource.data.companyDepartmentId
        && request.resource.data.managedCompanyIds == resource.data.managedCompanyIds;
      allow delete: if false;

      match /courses/{courseId} {
        allow read: if isOwner(userId) || isAdmin() || vendedorCanReadStudentUserSubpaths(userId);
        /**
         * Matrícula: callable no cadastro ou admin ao liberar curso na empresa.
         * merge: true conta como update — precisa permitir update para admin (aluno só escreve em …/modules).
         */
        allow create, update: if isAdmin();
        allow delete: if isAdmin();

        match /modules/{moduleId} {
          allow read: if isOwner(userId) || isAdmin() || vendedorCanReadStudentUserSubpaths(userId);
          allow create, update: if isOwner(userId);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }

      match /certificates/{courseId} {
        allow read: if isOwner(userId) || isAdmin() || vendedorCanReadStudentUserSubpaths(userId);
        allow create: if isOwner(userId)
          && request.resource.data.courseId == courseId
          && request.resource.data.keys().hasAll(['courseId', 'courseTitle', 'studentName', 'issuedAt', 'verificationCode']);
        allow update, delete: if isAdmin();
      }
    }

    match /courses/{courseId} {
      allow read: if resource.data.catalogPublished == true
        || (signedIn() && (isAdmin() || canReadCourseContent(courseId)));
      allow write: if isAdmin();

      match /modules/{moduleId} {
        allow read: if parentCourseCatalogPublic(courseId)
          || (signedIn() && (isAdmin() || canReadCourseContent(courseId)));
        allow write: if isAdmin();
      }
    }

    /** Gabaritos: alunos não leem; admin e vendedor (relatórios das empresas geridas). */
    match /answerKeys/{docId} {
      allow read: if isAdmin() || isVendedor();
      allow write: if isAdmin();
    }

    match /{path=**}/allowedCourses/{courseId} {
      allow read: if isAdmin();
    }

    /**
     * Canais (Streaming): leitura pública só se published; admin lê/edita todos.
     * Sem documento: permite `get` (exists=false) para a app mostrar “não encontrado” em vez de permission-denied.
     */
    match /channels/{channelId} {
      allow read: if !exists(/databases/$(database)/documents/channels/$(channelId))
        || resource.data.published == true
        || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * Banners promocionais no topo do Streaming.
     * Visitantes só leem documentos publicados; admin gere todos.
     */
    match /streamingBanners/{bannerId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * Textos das páginas públicas (Sobre, termos, privacidade etc.) em Markdown.
     * Leitura pública; edição só admin.
     */
    match /siteContent/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /** Home streaming: trilhas e vídeos Vimeo (leitura pública; escrita só admin). */
    match /streamingTracks/{trackId} {
      allow read: if true;
      allow write: if isAdmin();

      match /entries/{entryId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /** Agregados de visualização da home streaming (escrita só via Cloud Functions). */
    match /streamingEntryStats/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /streamingTrackStats/{trackId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    /** Cache de transcrições Vimeo para o assistente (só servidor). */
    match /streamingTranscriptCache/{entryId} {
      allow read, write: if false;
    }

    /** Quotas do assistente IA (só servidor via Admin SDK). */
    match /assistantQuota/{path=**} {
      allow read, write: if false;
    }
  }
}
